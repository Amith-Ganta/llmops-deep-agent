# --- LLM provider (required) ---
GROQ_API_KEY=your_groq_api_key

# --- Web search tool (optional; agent runs without it) ---
TAVILY_API_KEY=your_tavily_api_key

# --- Langfuse tracing (optional; tracing disabled if unset) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Agent configuration (defaults shown) ---
DEEPAGENT_MODEL=groq:llama-3.3-70b-versatile
SUBAGENT_MODEL=groq:llama-3.1-8b-instant
DEEPAGENT_BACKEND=StateBackend
ENABLE_WEB_SEARCH=true
ENABLE_SUBAGENTS=true
